{
  "manifest_version": 3,
  "name": "OPUS Live Tester",
  "version": "0.1.0",
  "description": "Workspace-only Chrome extension for live OPUS site checks.",
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1/*",
        "http://localhost/*"
      ],
      "js": [
        "opus-live-tester.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
