<?php
declare(strict_types=1);

namespace Opus\Scaffold;

/**
 * Scaffold plan for a full OPUS site/application.
 *
 * Contract:
 * - creates the application common layer;
 * - creates module registry containers;
 * - creates a starter Home module as the official generated welcome page;
 * - creates local resources and i18n starter content;
 * - creates a public front controller that renders only declared routes and .score templates;
 * - never imports external dependencies.
 */
final class SiteScaffoldPlan implements ScaffoldPlanInterface
{
    private function __construct(private readonly string $siteId)
    {
    }

    public static function forSite(string $siteId): self
    {
        return new self($siteId);
    }

    public function rootRelativePath(): string
    {
        return 'sites/' . $this->siteId;
    }

    /**
     * @return list<ScaffoldEntry>
     */
    public function entries(): array
    {
        $site = $this->siteId;

        $directories = [
            "sites/{$site}/application/config",
            "sites/{$site}/application/common/acl",
            "sites/{$site}/application/common/helpers",
            "sites/{$site}/application/common/assets",
            "sites/{$site}/application/common/javascript",
            "sites/{$site}/application/common/local",
            "sites/{$site}/application/common/models",
            "sites/{$site}/application/common/services",
            "sites/{$site}/application/common/view-models",
            "sites/{$site}/application/common/views",
            "sites/{$site}/application/common/templates/partials",
            "sites/{$site}/application/common/templates/components",
            "sites/{$site}/application/modules/Home/acl",
            "sites/{$site}/application/modules/Home/helpers",
            "sites/{$site}/application/modules/Home/assets",
            "sites/{$site}/application/modules/Home/javascript",
            "sites/{$site}/application/modules/Home/local",
            "sites/{$site}/application/modules/Home/models",
            "sites/{$site}/application/modules/Home/services",
            "sites/{$site}/application/modules/Home/controllers",
            "sites/{$site}/application/modules/Home/view-models",
            "sites/{$site}/application/modules/Home/views",
            "sites/{$site}/application/modules/Home/templates/pages",
            "sites/{$site}/application/modules/Home/templates/partials",
            "sites/{$site}/application/modules/Home/templates/components",
            "sites/{$site}/resources/content",
            "sites/{$site}/resources/i18n",
            "sites/{$site}/resources/themes",
            "sites/{$site}/resources/assets",
            "sites/{$site}/public/assets/css",
            "sites/{$site}/public/assets/js",
            "sites/{$site}/public/assets/img",
        ];

        $entries = array_map(static fn (string $directory): ScaffoldEntry => ScaffoldEntry::directory($directory), $directories);

        $entries[] = ScaffoldEntry::file("sites/{$site}/README.md", $this->readmeContent());
        $entries[] = ScaffoldEntry::file("sites/{$site}/START_HERE.md", $this->startHereContent());
        $entries[] = ScaffoldEntry::file("sites/{$site}/opus-site.json", $this->json([
            'site_id' => $site,
            'type' => 'opus-site',
            'contract' => 'OPUS_SITE_APPLICATION_V1',
            'starter_contract' => 'OPUS_CREATE_SITE_STARTER_HOME_V1',
            'external_dependencies_allowed' => false,
            'framework_duplication_allowed' => false,
            'created_by' => 'composer opus:create-site',
        ]));
        $entries[] = ScaffoldEntry::file("sites/{$site}/application/config/site.json", $this->json([
            'site_id' => $site,
            'site_name' => 'Nouveau site ' . $site,
            'contract' => 'OPUS_SITE_APPLICATION_V1',
            'default_locale' => 'fr',
            'locales' => ['fr', 'en'],
            'public_root' => 'public',
            'application_root' => 'application',
            'resources_root' => 'resources',
            'common_root' => 'application/common',
            'modules_root' => 'application/modules',
            'home_route' => 'home.index',
        ]));
        $entries[] = ScaffoldEntry::file("sites/{$site}/application/config/modules.json", $this->json([
            'contract' => 'OPUS_MODULE_REGISTRY_V1',
            'modules' => [
                [
                    'id' => 'Home',
                    'enabled' => true,
                    'contract' => 'OPUS_APPLICATION_MODULE_V1',
                    'role' => 'starter-home',
                    'created_by' => 'composer opus:create-site',
                ],
            ],
        ]));
        $entries[] = ScaffoldEntry::file("sites/{$site}/application/config/routes.json", $this->json([
            'contract' => 'OPUS_ROUTE_REGISTRY_V1',
            'routes' => [
                [
                    'id' => 'home.index',
                    'path' => '/',
                    'module' => 'Home',
                    'controller' => 'HomeController',
                    'action' => 'index',
                    'template' => 'application/modules/Home/templates/pages/home.score',
                    'label' => 'menu.home',
                    'acl' => 'public',
                    'fsm_state' => 'HOME',
                ],
            ],
        ]));
        $entries[] = ScaffoldEntry::file("sites/{$site}/application/config/fsm.json", $this->json([
            'contract' => 'OPUS_FSM_REGISTRY_V1',
            'initial_state' => 'HOME',
            'states' => [
                [
                    'id' => 'HOME',
                    'module' => 'Home',
                    'route' => 'home.index',
                    'role' => 'starter-home',
                ],
            ],
            'transitions' => [],
        ]));
        $entries[] = ScaffoldEntry::file("sites/{$site}/application/common/templates/layout.score", $this->commonLayoutScore());
        $entries[] = ScaffoldEntry::file("sites/{$site}/application/common/templates/components/header.score", $this->headerScore());
        $entries[] = ScaffoldEntry::file("sites/{$site}/application/common/templates/components/footer.score", $this->footerScore());
        $entries[] = ScaffoldEntry::file("sites/{$site}/application/common/templates/components/powered-by-opus.score", $this->poweredByScore());
        $entries[] = ScaffoldEntry::file("sites/{$site}/application/modules/Home/README.md", $this->homeModuleReadmeContent());
        $entries[] = ScaffoldEntry::file("sites/{$site}/application/modules/Home/module.json", $this->json([
            'module_id' => 'Home',
            'site_id' => $site,
            'contract' => 'OPUS_APPLICATION_MODULE_V1',
            'role' => 'starter-home',
            'inherits_common_layer' => true,
            'external_dependencies_allowed' => false,
            'html_rendering' => 'score-template',
            'created_by' => 'composer opus:create-site',
        ]));
        $entries[] = ScaffoldEntry::file("sites/{$site}/application/modules/Home/controllers/HomeController.php", $this->homeControllerContent());
        $entries[] = ScaffoldEntry::file("sites/{$site}/application/modules/Home/services/HomePageService.php", $this->homePageServiceContent());
        $entries[] = ScaffoldEntry::file("sites/{$site}/application/modules/Home/view-models/HomePageViewModel.php", $this->homePageViewModelContent());
        $entries[] = ScaffoldEntry::file("sites/{$site}/application/modules/Home/templates/layout.score", $this->homeLayoutScore());
        $entries[] = ScaffoldEntry::file("sites/{$site}/application/modules/Home/templates/pages/home.score", $this->homePageScore());
        $entries[] = ScaffoldEntry::file("sites/{$site}/application/modules/Home/templates/partials/implementation-help.score", $this->implementationHelpScore());
        $entries[] = ScaffoldEntry::file("sites/{$site}/resources/i18n/fr.json", $this->json($this->i18nFr()));
        $entries[] = ScaffoldEntry::file("sites/{$site}/resources/i18n/en.json", $this->json($this->i18nEn()));
        $entries[] = ScaffoldEntry::file("sites/{$site}/resources/content/home.fr.json", $this->json($this->homeContentFr($site)));
        $entries[] = ScaffoldEntry::file("sites/{$site}/resources/content/home.en.json", $this->json($this->homeContentEn($site)));
        $entries[] = ScaffoldEntry::file("sites/{$site}/public/assets/css/starter.css", $this->starterCss());
        $entries[] = ScaffoldEntry::file("sites/{$site}/public/index.php", $this->frontControllerContent());

        return $entries;
    }

    private function readmeContent(): string
    {
        return "# {$this->siteId}\n\nOPUS site/application scaffold generated by `composer opus:create-site`.\n\nThis is a professional starter site, not a blank folder and not a wild page.\n\n## Contract\n\n- Application is modular.\n- Common application resources live under `application/common`.\n- Business modules live under `application/modules`.\n- The generated Home module owns the starter home page.\n- Public entry point only resolves declared routes and renders `.score` templates.\n- HTML rendering must go through `.score` templates.\n- External dependencies are forbidden unless an explicit ADR allows them.\n\nRead `START_HERE.md` before modifying the site.\n";
    }

    private function startHereContent(): string
    {
        return "# Start here\n\nThis site was generated by `composer opus:create-site`.\n\n## First safe edits\n\n1. Edit `resources/content/home.fr.json` and `resources/content/home.en.json`.\n2. Edit `application/modules/Home/templates/pages/home.score`.\n3. Add business modules with `composer opus:create-module -- {$this->siteId} ModuleName --write`.\n4. Keep `public/index.php` as a front controller. Do not put page business logic there.\n5. Keep HTML in `.score` templates.\n6. Keep common assets/helpers/templates in `application/common`.\n7. Put module-specific resources in `application/modules/<ModuleName>`.\n\n## Rules\n\n- No wild page creation.\n- No module without a site.\n- No page outside a module.\n- No duplicated framework.\n- No external dependency unless contractually approved.\n";
    }

    private function commonLayoutScore(): string
    {
        return <<<'SCORE'
<!doctype html>
<html lang="{{ lang }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ page.title }}</title>
  <link rel="stylesheet" href="/assets/css/starter.css">
</head>
<body class="opus-starter-site">
  {{ common.header }}
  <main class="opus-main">
    {{ content }}
  </main>
  {{ common.footer }}
</body>
</html>
SCORE;
    }

    private function headerScore(): string
    {
        return <<<'SCORE'
<header class="opus-header">
  <div>
    <p class="opus-kicker">{{ site.framework }}</p>
    <h1>{{ site.name }}</h1>
  </div>
  <nav class="opus-nav" aria-label="{{ i18n.menu_label }}">
    <a href="/">{{ i18n.menu_home }}</a>
  </nav>
</header>
SCORE;
    }

    private function footerScore(): string
    {
        return <<<'SCORE'
<footer class="opus-footer">
  {{ common.powered_by }}
  <p>{{ site.copyright }}</p>
</footer>
SCORE;
    }

    private function poweredByScore(): string
    {
        return <<<'SCORE'
<p class="opus-powered">Powered by OPUS</p>
SCORE;
    }

    private function homeModuleReadmeContent(): string
    {
        return "# Home module\n\nGenerated by `composer opus:create-site` as the official starter home module.\n\n## Responsibility\n\n- Own the starter home route `/`.\n- Render the welcome page through `templates/pages/home.score`.\n- Read editable content from `resources/content/home.<locale>.json`.\n- Demonstrate the expected OPUS module structure.\n\nThis module is intentionally simple and self-documented. Patch it for the project's real needs after generation.\n";
    }

    private function homeControllerContent(): string
    {
        $namespace = $this->siteNamespace();

        return <<<PHP
<?php
declare(strict_types=1);

namespace OpusSite\\{$namespace}\\Home\\Controller;

/**
 * Starter Home controller skeleton.
 *
 * Contract:
 * - controller orchestrates the Home use case;
 * - it does not render HTML directly;
 * - it delegates data preparation to services/view-models;
 * - rendering belongs to .score templates.
 */
final class HomeController
{
    public function index(): void
    {
        // Implement project-specific orchestration here.
        // Do not concatenate HTML in this controller.
    }
}
PHP;
    }

    private function homePageServiceContent(): string
    {
        $namespace = $this->siteNamespace();

        return <<<PHP
<?php
declare(strict_types=1);

namespace OpusSite\\{$namespace}\\Home\\Service;

/**
 * Starter Home page service skeleton.
 *
 * Contract:
 * - service prepares/validates Home page data;
 * - service does not render HTML;
 * - service returns data for a view-model or response model.
 */
final class HomePageService
{
    /**
     * @return array<string, string>
     */
    public function loadStarterData(): array
    {
        return [
            'status' => 'starter',
        ];
    }
}
PHP;
    }

    private function homePageViewModelContent(): string
    {
        $namespace = $this->siteNamespace();

        return <<<PHP
<?php
declare(strict_types=1);

namespace OpusSite\\{$namespace}\\Home\\ViewModel;

/**
 * Starter Home view-model skeleton.
 *
 * Contract:
 * - view-model contains render-ready state;
 * - no business computation here;
 * - no HTML concatenation here.
 */
final class HomePageViewModel
{
    /**
     * @param array<string, mixed> \$data
     */
    public function __construct(private readonly array \$data)
    {
    }

    /**
     * @return array<string, mixed>
     */
    public function toArray(): array
    {
        return \$this->data;
    }
}
PHP;
    }

