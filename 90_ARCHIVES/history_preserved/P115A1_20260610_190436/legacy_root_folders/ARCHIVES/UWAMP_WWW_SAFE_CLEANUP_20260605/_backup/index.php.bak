    font-family:"Trebuchet MS", Verdana;
    font-size: 10pt;
    text-align: left;
    margin: 0px;
    padding: 0px;
}

.mainblock
{
    padding:50px;
    border : solid 1px #D9A6A6;
    background-color: #FFF5F5;
    width:798px;
    text-align:left;
}

a
{
    color: #A00000;
    font-weight: bold;
    text-decoration: none;
}

