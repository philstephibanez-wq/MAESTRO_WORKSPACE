<?php
$UWAMPFOLDER = "../";

/*
    UwAmp index.php original-like red diagnostic version.
    Objectif : garder une page d'accueil UwAmp reconnaissable,
    mais en dominante rouge pour identifier immédiatement
    que la requête tombe encore sur l'index UwAmp local.
*/

if (isset($_REQUEST['getimg']))
{
    $type = (string) $_GET['getimg'];

    if ($type === 'title') {
        header("Content-type: image/svg+xml; charset=utf-8");
        echo '<svg xmlns="http://www.w3.org/2000/svg" width="900" height="70" viewBox="0 0 900 70">
            <defs>
                <linearGradient id="g" x1="0" x2="1" y1="0" y2="0">
                    <stop offset="0" stop-color="#7A0000"/>
                    <stop offset="1" stop-color="#D00000"/>
                </linearGradient>
            </defs>
            <rect width="900" height="70" rx="8" fill="#fff5f5"/>
            <text x="22" y="48" font-family="Trebuchet MS, Verdana, Arial, sans-serif" font-size="44" font-weight="700" fill="url(#g)">UwAmp</text>
            <text x="190" y="48" font-family="Trebuchet MS, Verdana, Arial, sans-serif" font-size="18" fill="#8A0000">Apache PHP MySQL PHPMyAdmin serveur</text>
        </svg>';
        exit();
    }

    if ($type === 'folder') {
        header("Content-type: image/svg+xml; charset=utf-8");
        echo '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16">
            <path d="M1 4.2C1 3.5 1.5 3 2.2 3h4l1.3 1.5h6.3c.7 0 1.2.5 1.2 1.2v6.1c0 .7-.5 1.2-1.2 1.2H2.2C1.5 13 1 12.5 1 11.8V4.2z" fill="#C00000"/>
            <path d="M1 6h14v5.8c0 .7-.5 1.2-1.2 1.2H2.2C1.5 13 1 12.5 1 11.8V6z" fill="#E05A5A"/>
        </svg>';
        exit();
    }

    if ($type === 'favicon') {
        header("Content-type: image/svg+xml; charset=utf-8");
        echo '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 32 32">
            <rect width="32" height="32" rx="6" fill="#A00000"/>
            <text x="6" y="23" font-family="Trebuchet MS, Verdana, Arial, sans-serif" font-size="18" font-weight="700" fill="#ffffff">U</text>
        </svg>';
        exit();
    }

    http_response_code(404);
    exit();
}
?>
<html>
<head>
<title>UwAmp</title>
<link rel="shortcut icon" type="image/svg+xml" href="./?getimg=favicon" />
<style type="text/css">
body
{
    position:relative;
