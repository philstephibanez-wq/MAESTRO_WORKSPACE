<body>
<center>

<img src="./?getimg=title" />
<div class="mainblock">

<h2>Apache Work Fine!!!</h2>
<hr>
<h2>Configuration Setting</h2>
<li>Apache version : <?php echo $_SERVER['SERVER_SOFTWARE']; ?></li>
<li><a href="/mysql/">PHPMyAdmin</a></li>
<li><a href="/uwamp/phpinfo.php">PHP Info</a></li>
<br><br><hr>

<h2>Alias</h2>
<?php
echo '<pre style="background:#300;color:#fff;padding:20px;font-size:16px">';
echo 'HTTP_HOST = ' . ($_SERVER['HTTP_HOST'] ?? '') . PHP_EOL;
echo 'SERVER_NAME = ' . ($_SERVER['SERVER_NAME'] ?? '') . PHP_EOL;
echo 'DOCUMENT_ROOT = ' . ($_SERVER['DOCUMENT_ROOT'] ?? '') . PHP_EOL;
echo 'SCRIPT_FILENAME = ' . ($_SERVER['SCRIPT_FILENAME'] ?? '') . PHP_EOL;
echo '</pre>';
exit;
$apacheconffile = $UWAMPFOLDER . "bin/apache/conf/httpd.conf";
if (!file_exists($apacheconffile))
{
    echo "Can't find Apache config file (httpd.conf)";
}
else
{
    $fp = fopen($apacheconffile, 'r');
    $data = fread($fp, filesize($apacheconffile));
    fclose($fp);

    preg_match_all("/Alias[\\t ]*\"([^\"\']+)\"[\\t ]\"([^\"\']+)\"/i", $data, $matches, PREG_SET_ORDER);

    foreach ($matches as $val)
    {
        echo "<li><a class=\"afolder\" href=\"$val[1]\">$val[1]</a></li>";
    }
}
?>

<h2>Virtual Host</h2>
<?php
$wwwdir = $UWAMPFOLDER . "www";
$count = 0;

if (is_dir($wwwdir))
{
    $handle = opendir($wwwdir);

    while ($file = readdir($handle))
    {
        if ($file == "." || $file == "..") continue;

        if (is_dir($wwwdir . "/" . $file))
        {
            $count++;
            echo "<li><a class=\"afolder\" href=\"/$file\">$file</a></li>";
        }
    }

    closedir($handle);
}

if ($count == 0)
{
    echo "No project found";
}
?>

<br><br>
<hr>
<center><a href="http://www.uwamp.com">UwAmp Home</a></center>

</div>
</center>

</body>
</html>
